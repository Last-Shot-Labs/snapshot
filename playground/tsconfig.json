{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@lastshotlabs/snapshot/ui": ["../src/ui.ts"],
      "@lastshotlabs/snapshot": ["../src/index.ts"],
      "@lib/snapshot": ["./src/lib/snapshot.ts"]
    }
  },
  "include": ["src"]
}
